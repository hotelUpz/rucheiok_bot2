        },
        "extrime_close": {
            "enable": true,
            "order_timeout_sec": 0.5,
            "retry_ttl": 3,
            "retry_num": "inf",
            "bid_to_ask_orientation": 0.0,
            "increase_fraction": 5.0
        }
