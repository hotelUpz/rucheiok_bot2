        "margin_mode": 1
    },
    "credentials": {
        "api_key": "",
        "api_secret": ""
    },
    "tg": {
        "enable": true,
        "token": "",
        "chat_id": ""
    },
    "log": {
        "debug": true,
        "info": true,
        "warning": true,
        "error": true,
        "max_lines": 1500,
        "timezone": "UTC"
    },
    "white_list": [],
    "black_list": [
        "LABUSDT"
    ],
    "quota_asset": "USDT",
    "risk": {
        "leverage": {
            "_fields": {
                "margin_mode": "1 = Cross, 2 = Isolated"
            },
            "set_previous": false,
            "used_by_cache": false,
            "val": 10,
            "delay_sec": 0.3,
            "margin_mode": 1
        },
        "margin_size": "row",
        "notional_limit": 550,
        "margin_over_size_pct": 1,
        "hedge_mode": false,
        "quarantine": {
            "min_quarantine_threshold_usdt": -0.1,
            "force_quarantine_threshold_usdt": -1.5,
            "max_consecutive_fails": 2,
            "quarantine_hours": "inf"
        }
    },
    "entry": {
        "_fields": {
            "price_mode": "BEST (Ask1/Bid1) | MID (Between Ask1 and Bid1)"
        },
        "price_mode": "BEST",
        "signal_timeout_sec": 0.1,
        "entry_timeout_sec": 0.5,
        "max_place_order_retries": 1,
        "quarantine": {
            "quarantine_hours": 1
        },
        "allowed_directions": [
            "LONG"
        ],
        "pattern": {
            "funding_pattern1": {
                "enable": true,
                "check_interval_sec": 60,
                "skip_before_counter_sec": 10800,
                "threshold_pct": 1.5
            },
            "funding_pattern2": {
                "enable": true,
                "check_interval_sec": 60,
                "skip_before_counter_sec": 1800,
                "diff_threshold_pct": 0.05
            },
            "binance_trigger": {
                "_fields": {
                    "spread_mode": "BOOK (Asks vs Asks if LONG, Bids vs Bids if SHORT) | MID (Mid vs Mid) | TICKER (Last vs Last)"
                },
                "enable": true,
                "spread_mode": "BOOK",
                "spread_to_entry_pct": 0.5,
                "min_price_spread_rate": 0.8,
                "update_prices_sec": 0.25,
                "ttl_sec": 0.25
            },
            "fair_price_filter": {
                "enable": true,
                "min_fair_spread_pct": 0.0
            },
            "rsi_filter": {
                "enable": true,
                "interval": "1m",
                "limit": 50,
                "window": 14,
                "overbought": 80,
                "oversold": 20,
                "full_update_min": 10
            },
            "orderbook_filter": {
                "_fields": {
                    "max_spread_pct": "максимально допустимый разрыв в стакане Phemex ((ask-bid)/bid), иначе скип",
                    "dist_rate": "Phm_Ask1-Phm_Bid1 / p2-p1. Если > max_dist_rate, скип",
                    "rate": "spr3_pct / roc_sma. Если < desired_rate, скип"
                },
                "depth_limit": 8,
                "min_first_row_usdt_notional": 50,
                "max_first_row_usdt_notional": 500,
                "max_spread_pct": 0.75,
                "min_spr2_pct": 0.3,
                "min_spr3_pct": 0.35,
                "max_dist_rate": 0.75,
                "sma_window": 3,
                "roc_window": 5,
                "max_one_roc": 0.25,
                "desired_rate": 6,
                "pattern_ttl_sec": 0.25
            },
            "dex_filter": {
                "enable": true,
                "min_dex_spread_pct": 0.0
            }
        }
    },
    "exit": {
        "max_place_order_retries": 1,
        "min_order_life_sec": 0.05,
        "scenarios": {
            "base": {
                "enable": true,
                "target_rate": 0.75,
                "min_target_rate": 0.1,
